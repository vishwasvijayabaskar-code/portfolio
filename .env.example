# --- Optional env vars. Copy to .env.local for dev, or set in Vercel project settings. ---
# All gracefully fall back if missing.

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
# Without this, GA is not loaded at all.
VITE_GA_ID=

# --- Spotify "now playing" (powers ♪ row in status widget) ---
# These are SERVER-only (no VITE_ prefix). Used by /api/spotify.js on Vercel.
# Setup: register an app at https://developer.spotify.com/dashboard
# Then run a one-time OAuth flow to get a refresh token (see README).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
